<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/floatingLayout"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/floating_bg"
    android:padding="12dp">

    <!-- ===== 待机模式：一个开始按钮 ===== -->
    <LinearLayout
        android:id="@+id/layoutStandby"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="长截图"
            android:textSize="11sp"
            android:textColor="#AAAAAA"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnStart"
            android:layout_width="80dp"
            android:layout_height="48dp"
            android:text="▶ 开始"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#4CAF50"
            android:padding="0dp"
            android:minHeight="0dp"
            android:minWidth="0dp"/>
    </LinearLayout>

    <!-- ===== 截图模式：信息 + 操作按钮 ===== -->
    <LinearLayout
        android:id="@+id/layoutCapturing"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <!-- 标题 -->
        <TextView
            android:id="@+id/tvStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="截图中..."
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginBottom="8dp"/>

        <!-- 实时信息 -->
        <TextView
            android:id="@+id/tvHeight"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="高度: 0 px"
            android:textSize="11sp"
            android:textColor="#E0E0E0"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="大小: 0 KB"
            android:textSize="11sp"
            android:textColor="#FFC107"
            android:layout_marginBottom="2dp"/>

        <TextView
            android:id="@+id/tvFrames"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="帧数: 0"
            android:textSize="11sp"
            android:textColor="#E0E0E0"
            android:layout_marginBottom="10dp"/>

        <!-- 操作按钮 -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnCapture"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:text="截取"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2196F3"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnSave"
                android:layout_width="70dp"
                android:layout_height="38dp"
                android:text="保存"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#F44336"
                android:padding="0dp"
                android:minHeight="0dp"
                android:minWidth="0dp"/>
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="滚动后点击「截取」"
            android:textSize="9sp"
            android:textColor="#888888"
            android:layout_marginTop="6dp"/>
    </LinearLayout>

</LinearLayout>
